{
  "name": "gstin-toolkit",
  "version": "0.1.0",
  "description": "A TypeScript-first, dependency-free npm library for GSTIN validation, parsing, and decoding.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./zod": {
      "import": "./dist/zod.mjs",
      "require": "./dist/zod.js",
      "types": "./dist/zod.d.ts"
    },
    "./react": {
      "import": "./dist/react.mjs",
      "require": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test:cli": "npm run build && vitest run test/cli.test.ts"
    
  
  },

  "bin": {
    "gstin-toolkit": "./dist/cli.js"
  },

  "keywords": [
    "gstin",
    "gst",
    "india",
    "validation",
    "typescript",
    "parser"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.56.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
